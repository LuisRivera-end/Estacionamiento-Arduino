# =============================================================================
# Variables del stack LOCAL en Docker (modo primario offline)
# =============================================================================
# Copia este archivo a `.env.docker` y rellena los valores reales:
#     cp .env.docker.example .env.docker
# Luego:
#     docker compose --env-file .env.docker up -d --build
#
# `.env.docker` está en .gitignore — NO lo subas al repo.
# =============================================================================

# IP LAN de la laptop que hostea el stack (la que ven los Arduino y los
# navegadores de la red). Obténla con `ipconfig` (Windows) en la red de la
# escuela. Recomendado: reservar la IP por DHCP para que no cambie.
# OJO: las NEXT_PUBLIC_* del frontend se hornean en el build; si cambia esta IP
#      hay que reconstruir el frontend (`docker compose build frontend`).
LAN_HOST=192.168.1.50

# Contraseña del PostgreSQL local (elige una; queda dentro de Docker).
POSTGRES_PASSWORD=cambia_esta_clave_local

# Secreto JWT compartido entre GoTrue (firma) y el backend (verifica HS256).
# Mínimo 32 caracteres. Genera uno aleatorio, p.ej.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
LOCAL_JWT_SECRET=cambia_este_secreto_de_al_menos_32_caracteres

# Tokens de dispositivo Arduino. DEBEN coincidir con los de Render y con los
# de `entrada/wifi_credentials.h` / `salida/wifi_credentials.h`.
API_DEVICE_TOKEN_ENTRY=tu_token_de_entrada
API_DEVICE_TOKEN_EXIT=tu_token_de_salida

# Destino de la sincronización local -> nube: la cadena de conexión directa a
# la base de datos de Supabase (la misma SUPABASE_DB_URL de producción).
# Déjala vacía para desactivar el sync (el stack local sigue funcionando).
# Nota (R3): la conexión directa db.<ref>.supabase.co suele ser solo IPv6. Si la
# red de la escuela no tiene salida IPv6, usa el SESSION pooler de Supabase
# (host *.pooler.supabase.com:5432, usuario postgres.<ref>) — NO el 6543.
REMOTE_DB_URL=postgresql://postgres:TU_PASSWORD@db.TU_REF.supabase.co:5432/postgres

# Cada cuántos minutos el scheduler intenta el push automático.
SYNC_INTERVAL_MINUTES=10
# Timeout (s) para detectar "sin internet" al conectar al remoto.
SYNC_CONNECT_TIMEOUT_SECONDS=10

# Permite registrar cuentas nuevas en GoTrue. Ponlo en `true` para crear el
# primer admin; después cámbialo a `true`->`false` y `docker compose up -d gotrue`.
GOTRUE_DISABLE_SIGNUP=false

# (Opcional) Imagen de GoTrue si el tag por defecto no estuviera disponible.
# GOTRUE_IMAGE=supabase/auth:v2.158.1

# Fallback del puente cuando el backend local no responde.
RENDER_FALLBACK_URL=https://parking-api-9oag.onrender.com
# Timeout (s) del puente contra el target primario local antes de ir al fallback.
ARDUINO_BRIDGE_TIMEOUT=10

# Clave pública/anon que el frontend pasa a supabase-js. GoTrue standalone NO
# valida el header apikey (eso lo hace Kong en Supabase real), así que basta
# cualquier cadena no vacía en modo local.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY_LOCAL=local-anon-key
