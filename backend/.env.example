APP_ENV=development
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:3000
BOOTSTRAP_FIRST_USER_AS_ADMIN=true

SUPABASE_URL=
SUPABASE_SECRET_KEY=
SUPABASE_DB_URL=postgresql+asyncpg://postgres:postgres@localhost:54322/postgres
# Optional. If empty, the API derives it from SUPABASE_URL.
SUPABASE_JWKS_URL=

API_DEVICE_TOKEN_ENTRY=
API_DEVICE_TOKEN_EXIT=

# -----------------------------------------------------------------------------
# Sincronización local -> nube (solo modo Docker local). En Render déjalas
# vacías/sin definir: sin REMOTE_DB_URL la sincronización queda deshabilitada.
# -----------------------------------------------------------------------------
# Cadena de conexión a la base de datos remota (Supabase) destino del push.
REMOTE_DB_URL=
# Cada cuántos minutos intenta el scheduler el push automático.
SYNC_INTERVAL_MINUTES=10
# Timeout (s) al conectar al remoto; sirve para detectar "sin internet" rápido.
SYNC_CONNECT_TIMEOUT_SECONDS=10
