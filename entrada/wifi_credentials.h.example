// =============================================================================
// wifi_credentials.h.example — PLANTILLA DE CONFIGURACIÓN
// =============================================================================
// Copia este archivo como "wifi_credentials.h" y rellena con tus datos reales.
// El archivo wifi_credentials.h está en .gitignore y NO se sube al repositorio.
//
//   Paso 1: Copiar   →  cp wifi_credentials.h.example wifi_credentials.h
//   Paso 2: Editar   →  Reemplaza los valores placeholder con los reales
//   Paso 3: Flashear →  Sube el código al Arduino Mega
// =============================================================================

#ifndef WIFI_CREDENTIALS_H
#define WIFI_CREDENTIALS_H

// --- Credenciales de Red Wi-Fi ---
#define WIFI_SSID "TU_RED_WIFI"
#define WIFI_PASS "TU_PASSWORD_WIFI"

// --- Servidor Backend (Render) ---
// Usa el dominio de Render sin https://
#define SERVER_HOST "parking-api-9oag.onrender.com"
#define SERVER_PORT 443
#define USE_SSL     true

// --- Token de autenticación del dispositivo ENTRADA ---
// Este valor debe coincidir con la variable de entorno
// API_DEVICE_TOKEN_ENTRY configurada en Render Dashboard.
// En desarrollo local, el valor por defecto es "entry-test-token".
#define DEVICE_TOKEN_ENTRY "CAMBIAR_TOKEN_ENTRADA"

// --- Token de autenticación del dispositivo SALIDA ---
// Este valor debe coincidir con la variable de entorno
// API_DEVICE_TOKEN_EXIT configurada en Render Dashboard.
// En desarrollo local, el valor por defecto es "exit-test-token".
#define DEVICE_TOKEN_EXIT "CAMBIAR_TOKEN_SALIDA"

#endif
